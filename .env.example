# Example environment variables (DO NOT COMMIT actual secrets)
# Copy this file to `.env` and fill values locally.

# Firebase (public keys are okay for some Firebase features, but avoid embedding secrets)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google OAuth client ID used by Expo Auth Session
EXPO_PUBLIC_EXPO_WEB_CLIENT_ID=
EXPO_PUBLIC_EXPO_ANDROID_CLIENT_ID=
EXPO_PUBLIC_EXPO_IOS_CLIENT_ID=
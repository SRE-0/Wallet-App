{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@firebase/auth": [
        "./node_modules/@firebase/auth/dist/index.rn.d.ts"
      ],
      "@/*": [
        "./*"
      ],
      "@components/*": ["/components/*"],
      "@features/*": ["/features/*"],
      "@hooks/*": ["/hooks/*"],
      "@authHooks/*": ["/features/auth/hooks/*"],
      "@utils/*": ["/utils/*"],
      "@constants/*": ["/constants/*"],
      "@models/*": ["/models/*"],
      "@screens/*": ["/screens/*"],
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
, "App.tsx"  ]
}
